---
---

<section class="bg-warm-cream relative overflow-hidden">
  <!-- Decorative blob -->
  <div
    class="absolute -right-32 top-1/2 -translate-y-1/2 w-[500px] h-[500px] rounded-full pointer-events-none"
    style="background: radial-gradient(circle, #EEF1FB 0%, transparent 70%); opacity: 0.7;"
    aria-hidden="true"
  ></div>

  <div class="section-container py-20 lg:py-28 relative z-10">
    <div class="max-w-2xl">
      <!-- Eyebrow -->
      <div class="inline-flex items-center gap-2 bg-periwinkle/10 text-periwinkle font-semibold text-xs tracking-widest uppercase px-4 py-2 rounded-full mb-7">
        <span class="w-1.5 h-1.5 bg-periwinkle rounded-full"></span>
        Registered Community Interest Company
      </div>

      <!-- Heading -->
      <h1 class="font-bold text-4xl sm:text-5xl lg:text-6xl text-charcoal leading-[1.1] mb-6" style="font-family: 'Montserrat', sans-serif;">
        Everyone Deserves a Place to Call Home
      </h1>

      <!-- Subtitle -->
      <p class="text-muted text-lg sm:text-xl leading-relaxed mb-9 max-w-xl">
        We connect vulnerable individuals with safe, quality housing across Birmingham.
        If you have a client who needs housing, we can help.
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-4">
        <a href="/refer" class="btn-primary text-base px-8 py-4">
          Make a Referral
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </a>
        <a href="/how-it-works" class="btn-secondary text-base px-8 py-4">
          See how it works
        </a>
      </div>
    </div>
  </div>
</section>

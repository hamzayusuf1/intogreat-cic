---
---

<section class="bg-white py-20 lg:py-24">
  <div class="section-container">
    <!-- Section header -->
    <div class="max-w-2xl mb-12">
      <p class="text-periwinkle font-semibold text-sm uppercase tracking-widest mb-3">Real Stories</p>
      <h2 class="section-heading mb-4">Making a real difference</h2>
      <p class="text-muted text-lg leading-relaxed">
        Behind every referral is a person rebuilding their life. Here's what that looks like.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-14 items-start">

      <!-- Instagram CTA -->
      <div class="flex flex-col gap-5">
        <a
          href="https://www.instagram.com/intogreathousing"
          target="_blank"
          rel="noopener noreferrer"
          class="group block bg-gradient-to-br from-[#833AB4] via-[#FD1D1D] to-[#F77737] rounded-2xl p-8 text-white text-center hover:opacity-95 transition-opacity duration-200"
        >
          <div class="w-16 h-16 bg-white/20 rounded-2xl flex items-center justify-center mx-auto mb-5">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-9 h-9 text-white" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </div>
          <h3 class="font-bold text-xl mb-2" style="font-family: 'Montserrat', sans-serif;">Follow our work on Instagram</h3>
          <p class="text-white/85 text-sm leading-relaxed mb-4">
            See the real stories behind our work — the people we've helped find safe, stable homes across Birmingham.
          </p>
          <span class="inline-flex items-center gap-2 bg-white/20 hover:bg-white/30 transition-colors px-5 py-2.5 rounded-xl font-semibold text-sm">
            @intogreathousing
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
          </span>
        </a>

        <div class="bg-warm-cream rounded-2xl p-6 text-center">
          <p class="text-muted text-sm leading-relaxed">
            Have footage or testimonials to share? We can embed a video here in future — just let us know.
          </p>
        </div>
      </div>

      <!-- Impact statements -->
      <div class="flex flex-col gap-6">
        <div class="flex items-start gap-5 p-6 bg-warm-cream rounded-2xl">
          <div class="w-12 h-12 bg-periwinkle/10 rounded-xl flex items-center justify-center flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-periwinkle" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
            </svg>
          </div>
          <div>
            <p class="font-bold text-charcoal mb-1" style="font-family: 'Montserrat', sans-serif;">Families housed across Birmingham</p>
            <p class="text-muted text-sm leading-relaxed">We have helped individuals and families find safe, stable housing across the city — people who had nowhere else to turn.</p>
          </div>
        </div>

        <div class="flex items-start gap-5 p-6 bg-periwinkle-light rounded-2xl">
          <div class="w-12 h-12 bg-periwinkle/15 rounded-xl flex items-center justify-center flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-periwinkle" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <div>
            <p class="font-bold text-charcoal mb-1" style="font-family: 'Montserrat', sans-serif;">Vetted housing providers in our network</p>
            <p class="text-muted text-sm leading-relaxed">Every provider we work with is assessed to ensure their properties are safe, compliant, and suitable for the individuals we refer.</p>
          </div>
        </div>

        <div class="flex items-start gap-5 p-6 bg-warm-cream rounded-2xl">
          <div class="w-12 h-12 bg-charcoal/5 rounded-xl flex items-center justify-center flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-charcoal" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <div>
            <p class="font-bold text-charcoal mb-1" style="font-family: 'Montserrat', sans-serif;">Referrals responded to within 24 hours</p>
            <p class="text-muted text-sm leading-relaxed">We know urgency matters. We respond to every referral within 24 hours and move quickly when the situation demands it.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

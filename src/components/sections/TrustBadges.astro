---
const badges = [
  {
    title: 'Registered Community Interest Company',
    detail: 'Company No. 16652757',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />`,
  },
  {
    title: 'Vetted Housing Providers Only',
    detail: 'Every provider assessed before joining our network',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />`,
  },
  {
    title: 'No Cost to the Individual',
    detail: 'Housing providers pay — never the person being housed',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />`,
  },
  {
    title: 'Birmingham-Based Team',
    detail: 'We know the city and its housing landscape',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />`,
  },
];
---

<section class="bg-warm-cream py-16 lg:py-20">
  <div class="section-container">
    <div class="text-center mb-12">
      <p class="text-periwinkle font-semibold text-sm uppercase tracking-widest mb-3">Why organisations trust us</p>
      <h2 class="section-heading">A referral partner you can rely on</h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {badges.map((badge) => (
        <div class="bg-white rounded-2xl p-7 text-center shadow-sm border border-gray-50">
          <div class="w-14 h-14 bg-periwinkle/10 rounded-2xl flex items-center justify-center mx-auto mb-5">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-periwinkle" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" set:html={badge.icon}></svg>
          </div>
          <h3 class="font-bold text-charcoal text-base mb-2 leading-snug" style="font-family: 'Montserrat', sans-serif;">{badge.title}</h3>
          <p class="text-muted text-sm leading-relaxed">{badge.detail}</p>
        </div>
      ))}
    </div>
  </div>
</section>

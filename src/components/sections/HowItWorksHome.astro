---
const steps = [
  {
    number: '01',
    title: 'You refer someone to us',
    description: 'A charity, social worker, or support organisation contacts us about someone who needs housing. You can call, email, or use the referral form on this website, whichever is easiest.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />`,
  },
  {
    number: '02',
    title: 'We find the right match',
    description: 'We look across our network of vetted housing providers to find a suitable placement, taking into account the person\'s needs, support requirements, and location preferences.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />`,
  },
  {
    number: '03',
    title: 'They move into safe accommodation',
    description: 'We coordinate the move-in with the housing provider and check back afterwards to make sure things are working. The person has a safe home, and it cost them nothing.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />`,
  },
];
---

<section class="bg-periwinkle-light py-20 lg:py-24">
  <div class="section-container">
    <!-- Section header -->
    <div class="max-w-2xl mb-14">
      <p class="text-periwinkle font-semibold text-sm uppercase tracking-widest mb-3">The Process</p>
      <h2 class="section-heading mb-4">Simple. Clear. Human.</h2>
      <p class="text-muted text-lg leading-relaxed">
        Our process is designed to be as straightforward as possible for the charities and organisations referring to us.
      </p>
    </div>

    <!-- Steps -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-6 relative">

      <!-- Connecting line (desktop) -->
      <div class="hidden md:block absolute top-8 left-[calc(16.67%+1rem)] right-[calc(16.67%+1rem)] h-px bg-periwinkle/20 z-0" aria-hidden="true"></div>

      {steps.map((step) => (
        <div class="relative bg-white rounded-2xl p-8 shadow-sm">
          <!-- Number badge -->
          <div class="w-12 h-12 bg-periwinkle rounded-xl flex items-center justify-center mb-6 relative z-10">
            <span class="text-white font-bold text-sm" style="font-family: 'Montserrat', sans-serif;">{step.number}</span>
          </div>

          <!-- Icon -->
          <div class="mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-periwinkle" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" set:html={step.icon}></svg>
          </div>

          <h3 class="text-lg font-bold text-charcoal mb-3" style="font-family: 'Montserrat', sans-serif;">{step.title}</h3>
          <p class="text-muted leading-relaxed text-sm">{step.description}</p>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="mt-12 text-center">
      <a href="/how-it-works" class="btn-secondary text-base inline-flex">
        Full step-by-step guide
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
        </svg>
      </a>
    </div>
  </div>
</section>

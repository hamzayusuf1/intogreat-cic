---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About Us' },
  { href: '/how-it-works', label: 'How We Work' },
  { href: '/contact', label: 'Contact' },
];

const pathname = Astro.url.pathname;
const isHome = pathname === '/';
---

<header class="bg-white border-b border-gray-100 sticky top-0 z-50">
  <div class="section-container">
    <div class="flex items-center justify-between h-20">

      <a href="/" class="flex-shrink-0" aria-label="Intogreat CIC — Home">
        <img
          src="/logo-nav.png"
          alt="Intogreat CIC"
          class="h-14 w-auto"
        />
      </a>

      <nav class="hidden lg:flex items-center gap-7" aria-label="Main navigation">
        {navLinks.map(({ href, label }) => (
          <a
            href={href}
            class={`text-sm font-medium transition-colors duration-200 pb-0.5 border-b-2 ${
              pathname === href
                ? 'text-purple border-purple'
                : 'text-charcoal-light border-transparent hover:text-purple hover:border-purple/40'
            }`}
            style="font-family: 'Poppins', sans-serif;"
          >
            {label}
          </a>
        ))}
      </nav>

      <div class="hidden lg:block">
        <a href="/refer" class="btn-primary text-sm">
          Make a Referral
        </a>
      </div>

      <button
        id="mobile-menu-btn"
        class="lg:hidden p-2 text-charcoal-light hover:text-purple transition-colors"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <svg id="icon-open" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="lg:hidden hidden border-t border-gray-100 bg-white">
    <nav class="section-container py-5 flex flex-col gap-1" aria-label="Mobile navigation">
      {navLinks.map(({ href, label }) => (
        <a
          href={href}
          class={`px-4 py-3 rounded-lg text-base font-medium transition-colors duration-200 ${
            pathname === href
              ? 'bg-purple-light text-purple'
              : 'text-charcoal-light hover:bg-warm-cream'
          }`}
          style="font-family: 'Poppins', sans-serif;"
        >
          {label}
        </a>
      ))}
      <a href="/refer" class="mt-3 btn-primary text-sm w-full text-center">
        Make a Referral
      </a>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden', !isOpen);
    iconClose?.classList.toggle('hidden', isOpen);
    btn.setAttribute('aria-expanded', String(!isOpen));
  });
</script>

---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About Us' },
  { href: '/how-it-works', label: 'How It Works' },
  { href: '/contact', label: 'Contact' },
];

const pathname = Astro.url.pathname;
---

<header class="bg-white border-b border-gray-100 sticky top-0 z-50">
  <div class="section-container">
    <div class="flex items-center justify-between h-18 py-4">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 flex-shrink-0" aria-label="Intogreat Housing CIC — Home">
        <img
          src="/logo-nav.png"
          alt="Intogreat Housing CIC"
          class="h-10 w-auto"
        />
      </a>

      <!-- Desktop nav -->
      <nav class="hidden lg:flex items-center gap-8" aria-label="Main navigation">
        {navLinks.map(({ href, label }) => (
          <a
            href={href}
            class={`text-sm font-medium transition-colors duration-200 ${
              pathname === href
                ? 'text-periwinkle'
                : 'text-charcoal hover:text-periwinkle'
            }`}
          >
            {label}
          </a>
        ))}
      </nav>

      <!-- Desktop CTA -->
      <div class="hidden lg:block">
        <a href="/refer" class="btn-primary text-sm">
          Make a Referral
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </a>
      </div>

      <!-- Mobile hamburger -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden p-2 text-charcoal hover:text-periwinkle transition-colors"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <svg id="icon-open" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="lg:hidden hidden border-t border-gray-100 bg-white">
    <nav class="section-container py-4 flex flex-col gap-1" aria-label="Mobile navigation">
      {navLinks.map(({ href, label }) => (
        <a
          href={href}
          class={`px-4 py-3 rounded-lg text-base font-medium transition-colors duration-200 ${
            pathname === href
              ? 'bg-periwinkle-light text-periwinkle'
              : 'text-charcoal hover:bg-warm-cream'
          }`}
        >
          {label}
        </a>
      ))}
      <a href="/refer" class="mt-3 btn-primary text-base w-full text-center">
        Make a Referral
      </a>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden', !isOpen);
    iconClose?.classList.toggle('hidden', isOpen);
    btn.setAttribute('aria-expanded', String(!isOpen));
  });
</script>

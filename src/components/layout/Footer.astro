---
---

<footer class="bg-charcoal text-white">
  <div class="section-container py-14 lg:py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">

      <div class="lg:col-span-2">
        <a href="/" class="inline-block mb-5" aria-label="Home">
          <div class="bg-white/10 rounded-lg px-3 py-2 inline-block">
            <img src="/logo-nav.png" alt="Intogreat CIC" class="h-9 w-auto" />
          </div>
        </a>
        <p class="text-white/70 leading-relaxed max-w-sm text-sm">
          Supporting people through the transition into independent housing, and staying in touch while they find their feet.
        </p>
      </div>

      <div>
        <h3 class="font-semibold text-sm uppercase tracking-wider text-white/50 mb-5" style="font-family: 'Inter', sans-serif;">Navigation</h3>
        <ul class="space-y-3">
          {[
            { href: '/', label: 'Home' },
            { href: '/about', label: 'About Us' },
            { href: '/how-it-works', label: 'How We Work' },
            { href: '/refer', label: 'Make a Referral' },
            { href: '/contact', label: 'Contact' },
          ].map(({ href, label }) => (
            <li>
              <a href={href} class="text-white/70 hover:text-white transition-colors duration-200 text-sm">
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="font-semibold text-sm uppercase tracking-wider text-white/50 mb-5" style="font-family: 'Inter', sans-serif;">Get in Touch</h3>
        <ul class="space-y-3">
          <li>
            <a href="tel:+447507112497" class="text-white/70 hover:text-white transition-colors duration-200 text-sm" style="font-family: 'Poppins', sans-serif;">
              07507 112 497
            </a>
          </li>
          <li>
            <a href="mailto:info@intogreathousing.co.uk" class="text-white/70 hover:text-white transition-colors duration-200 text-sm">
              info@intogreathousing.co.uk
            </a>
          </li>
          <li class="text-white/70 text-sm">
            Birmingham, West Midlands
          </li>
        </ul>
      </div>
    </div>
  </div>

  <div class="border-t border-white/10">
    <div class="section-container py-5 flex flex-col sm:flex-row justify-between items-center gap-3">
      <p class="text-white/40 text-xs text-center sm:text-left">
        &copy; {new Date().getFullYear()} Intogreat Housing and Support Services CIC. Company No. 16652757. Registered in England &amp; Wales.
      </p>
      <p class="text-white/40 text-xs">
        63 Grove Lane, Handsworth, Birmingham, B21 9HE
      </p>
    </div>
  </div>
</footer>

---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Make a Referral"
  description="Refer someone who needs safe housing in Birmingham. We respond within 24 hours. For charities, social workers, and support organisations."
>

  <!-- Page hero -->
  <section class="bg-warm-cream py-14 lg:py-16">
    <div class="section-container">
      <div class="max-w-2xl">
        <p class="text-periwinkle font-semibold text-sm uppercase tracking-widest mb-3">Make a Referral</p>
        <h1 class="font-bold text-4xl sm:text-5xl text-charcoal leading-tight mb-5" style="font-family: 'Montserrat', sans-serif;">
          Refer Someone Who Needs Housing
        </h1>
        <p class="text-muted text-lg leading-relaxed">
          If you're a charity, support organisation, or professional working with someone who needs safe housing in Birmingham, fill in the form below. We'll be in touch within 24 hours.
        </p>
      </div>
    </div>
  </section>

  <!-- Form section -->
  <section class="bg-white py-14 lg:py-20">
    <div class="section-container">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 lg:gap-16">

        <!-- Form -->
        <div class="lg:col-span-2">
          <form
            id="referral-form"
            action="https://formspree.io/f/mnjwqjze"
            method="POST"
          >
            <!-- Hidden fields for Formspree -->
            <input type="hidden" name="_subject" value="New housing referral — Intogreat Housing CIC" />
            <input type="hidden" name="_replyto" id="reply-to-field" value="" />

            <div class="space-y-6">
              <h2 class="font-bold text-xl text-charcoal mb-2" style="font-family: 'Montserrat', sans-serif;">Your details</h2>

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <div>
                  <label for="your-name" class="form-label">Your name <span class="text-red-400">*</span></label>
                  <input
                    id="your-name"
                    name="your_name"
                    type="text"
                    required
                    placeholder="Full name"
                    class="form-input"
                  />
                </div>
                <div>
                  <label for="organisation" class="form-label">Your organisation <span class="text-red-400">*</span></label>
                  <input
                    id="organisation"
                    name="organisation"
                    type="text"
                    required
                    placeholder="Charity or organisation name"
                    class="form-input"
                  />
                </div>
              </div>

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <div>
                  <label for="your-email" class="form-label">Your email <span class="text-red-400">*</span></label>
                  <input
                    id="your-email"
                    name="email"
                    type="email"
                    required
                    placeholder="your@email.com"
                    class="form-input"
                  />
                </div>
                <div>
                  <label for="your-phone" class="form-label">Your phone number <span class="text-red-400">*</span></label>
                  <input
                    id="your-phone"
                    name="phone"
                    type="tel"
                    required
                    placeholder="e.g. 07700 000000"
                    class="form-input"
                  />
                </div>
              </div>

              <hr class="border-gray-100 my-2" />

              <h2 class="font-bold text-xl text-charcoal mb-2" style="font-family: 'Montserrat', sans-serif;">About the individual</h2>

              <div>
                <label for="individual-name" class="form-label">Individual's first name <span class="text-red-400">*</span></label>
                <input
                  id="individual-name"
                  name="individual_name"
                  type="text"
                  required
                  placeholder="First name only is fine"
                  class="form-input"
                />
              </div>

              <div>
                <label for="situation" class="form-label">Individual's situation <span class="text-red-400">*</span></label>
                <div class="relative">
                  <select id="situation" name="situation" required class="form-select pr-10">
                    <option value="" disabled selected>Select a situation</option>
                    <option value="leave-to-remain">Granted leave to remain</option>
                    <option value="homeless-at-risk">Homeless or at risk of homelessness</option>
                    <option value="other-support-needs">Other support needs</option>
                    <option value="prefer-to-discuss">Prefer to discuss by phone</option>
                  </select>
                  <div class="pointer-events-none absolute inset-y-0 right-3 flex items-center" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-muted" viewBox="0 0 20 20" fill="currentColor">
                      <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
                    </svg>
                  </div>
                </div>
              </div>

              <div>
                <label for="urgency" class="form-label">Urgency <span class="text-red-400">*</span></label>
                <div class="relative">
                  <select id="urgency" name="urgency" required class="form-select pr-10">
                    <option value="" disabled selected>Select urgency</option>
                    <option value="urgent-48h">Urgent — within 48 hours</option>
                    <option value="within-week">Within a week</option>
                    <option value="within-month">Within a month</option>
                    <option value="not-urgent">Not urgent</option>
                  </select>
                  <div class="pointer-events-none absolute inset-y-0 right-3 flex items-center" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-muted" viewBox="0 0 20 20" fill="currentColor">
                      <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
                    </svg>
                  </div>
                </div>
              </div>

              <div>
                <label for="additional-info" class="form-label">Additional information <span class="text-muted font-normal">(optional)</span></label>
                <textarea
                  id="additional-info"
                  name="additional_info"
                  rows="5"
                  placeholder="Anything else we should know — support needs, location preferences, context about their situation..."
                  class="form-textarea"
                ></textarea>
              </div>

              <!-- Error/success messages -->
              <div id="form-error" class="hidden p-4 bg-red-50 border border-red-200 rounded-xl text-red-700 text-sm">
                Something went wrong. Please try again or call us directly.
              </div>
              <div id="form-success" class="hidden p-6 bg-green-50 border border-green-200 rounded-xl text-center">
                <div class="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-3">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-green-600" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                  </svg>
                </div>
                <p class="font-bold text-green-800 mb-1">Referral received — thank you.</p>
                <p class="text-green-700 text-sm">We'll be in touch within 24 hours. If it's urgent, please call us directly.</p>
              </div>

              <button
                type="submit"
                id="submit-btn"
                class="w-full btn-primary text-base py-4 justify-center"
              >
                Submit Referral
              </button>

              <p class="text-xs text-muted text-center">
                All referrals are handled confidentially in line with data protection requirements.
              </p>
            </div>
          </form>
        </div>

        <!-- Sidebar -->
        <div class="space-y-6">
          <div class="bg-warm-cream rounded-2xl p-7">
            <h3 class="font-bold text-charcoal mb-3" style="font-family: 'Montserrat', sans-serif;">Prefer to call?</h3>
            <p class="text-muted text-sm leading-relaxed mb-4">
              If the situation is urgent, or you'd rather speak to someone directly, call us now.
            </p>
            <a href="tel:+447507112497" class="flex items-center gap-2 text-periwinkle font-semibold hover:text-periwinkle-dark transition-colors duration-200">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 20 20" fill="currentColor">
                <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" />
              </svg>
              07507 112 497
            </a>
          </div>

          <div class="bg-periwinkle-light rounded-2xl p-7">
            <h3 class="font-bold text-charcoal mb-3" style="font-family: 'Montserrat', sans-serif;">What happens next?</h3>
            <ul class="space-y-3">
              {[
                'We acknowledge your referral within 24 hours',
                'We may call to clarify details',
                'We identify a suitable placement',
                'We confirm the match and coordinate move-in',
              ].map((item) => (
                <li class="flex items-start gap-2.5 text-sm text-muted">
                  <span class="w-5 h-5 bg-periwinkle/15 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 text-periwinkle" viewBox="0 0 20 20" fill="currentColor">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                    </svg>
                  </span>
                  {item}
                </li>
              ))}
            </ul>
          </div>

          <div class="p-6 border border-gray-200 rounded-2xl">
            <div class="flex items-start gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-periwinkle flex-shrink-0 mt-0.5" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd" />
              </svg>
              <div>
                <p class="font-semibold text-charcoal text-sm mb-1">Handled confidentially</p>
                <p class="text-muted text-xs leading-relaxed">
                  All information you share is treated with strict confidentiality and used only to facilitate the housing referral.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('referral-form') as HTMLFormElement | null;
  const emailInput = document.getElementById('your-email') as HTMLInputElement | null;
  const replyToField = document.getElementById('reply-to-field') as HTMLInputElement | null;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;
  const errorDiv = document.getElementById('form-error');
  const successDiv = document.getElementById('form-success');

  emailInput?.addEventListener('input', () => {
    if (replyToField) replyToField.value = emailInput.value;
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!submitBtn) return;

    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending...';
    errorDiv?.classList.add('hidden');

    try {
      const response = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' },
      });

      if (response.ok) {
        form.classList.add('hidden');
        successDiv?.classList.remove('hidden');
      } else {
        errorDiv?.classList.remove('hidden');
        submitBtn.disabled = false;
        submitBtn.textContent = 'Submit Referral';
      }
    } catch {
      errorDiv?.classList.remove('hidden');
      submitBtn.disabled = false;
      submitBtn.textContent = 'Submit Referral';
    }
  });
</script>
